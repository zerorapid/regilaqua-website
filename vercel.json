{
  "rewrites": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "admin.regilaqua.in"
        }
      ],
      "destination": "/admin.html"
    },
    {
      "source": "/manage/:path*",
      "destination": "/admin.html"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
